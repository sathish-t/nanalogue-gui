#!/usr/bin/env bash
# Ensure AGENTS.md remains a symbolic link to CLAUDE.md.
# Tools like sed -i silently replace symlinks with regular files.
if [ ! -L AGENTS.md ] || [ "$(readlink AGENTS.md)" != "CLAUDE.md" ]; then
  echo "pre-commit: AGENTS.md must be a symbolic link to CLAUDE.md" >&2
  echo "  Fix with: rm AGENTS.md && ln -s CLAUDE.md AGENTS.md" >&2
  exit 1
fi

# Keeps package-lock.json in sync with package.json so that
# npm ci in CI does not fail on optional-dependency mismatches.

# Load nvm (shell function, not on PATH in non-interactive shells)
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
# shellcheck source=/dev/null
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

if git diff --cached --name-only | grep -q '^package\(-lock\)\?\.json$'; then
  # Use the staged version of package.json for lock file generation
  cp package.json package.json.bak
  trap '[ -f package.json.bak ] && mv package.json.bak package.json' EXIT INT TERM

  staged_pkg=$(mktemp)
  git show :package.json > "$staged_pkg"
  cp "$staged_pkg" package.json
  rm "$staged_pkg"

  # Use Node 22 (minimum supported version) so the lock file is
  # compatible with npm ci on both Node 22 and Node 24 in CI.
  if ! nvm exec 22 npm install --package-lock-only --ignore-scripts; then
    echo "pre-commit: npm install --package-lock-only failed, aborting commit" >&2
    exit 1
  fi

  mv package.json.bak package.json
  trap - EXIT INT TERM
  git add package-lock.json
fi

# Check markdown links whenever any .md file is staged.
# --cached-only limits the check to staged/committed files so that local
# untracked draft markdown files cannot block unrelated commits.
if git diff --cached --name-only | grep -q '\.md$'; then
  if ! node scripts/check-md-links.mjs --cached-only; then
    echo "pre-commit: markdown link check failed, aborting commit" >&2
    exit 1
  fi
fi

# Validate CHANGELOG.md format whenever it is staged.
if git diff --cached --name-only | grep -q '^CHANGELOG\.md$'; then
  if ! node scripts/validate-changelog.mjs; then
    echo "pre-commit: CHANGELOG.md validation failed, aborting commit" >&2
    exit 1
  fi
fi

# Validate CSS comments whenever any src/ CSS file is staged.
if git diff --cached --name-only | grep -q '\.css$'; then
  if ! node scripts/validate-css-comments.mjs; then
    echo "pre-commit: CSS comment validation failed, aborting commit" >&2
    exit 1
  fi
fi

# Regenerate documentation/script-tree.md whenever src/ files are staged.
if git diff --cached --name-only | grep -q '^src/'; then
  if ! node scripts/generate-script-tree.mjs; then
    echo "pre-commit: generate-script-tree.mjs failed, aborting commit" >&2
    exit 1
  fi
  git add documentation/script-tree.md
fi

# Enforce coverage floor whenever any src/ TypeScript file is staged.
# New files must debut at 100%; existing files must not regress.
# On a clean pass the TSV floor is updated and staged automatically.
if git diff --cached --name-only | grep -q '^src/.*\.ts$'; then
  if ! node scripts/check-coverage.mjs; then
    echo "pre-commit: coverage check failed, aborting commit" >&2
    exit 1
  fi
  git add documentation/script-coverage.tsv
fi

# Enforce per-file line-count limits whenever any src/ TypeScript file is staged.
# Source files: max 800 lines. Test files: max 1500 lines.
# Grandfathered exceptions (files already above their ceiling) must not grow further.
if git diff --cached --name-only | grep -q '^src/.*\.ts$'; then
  if ! node scripts/check-file-size.mjs; then
    echo "pre-commit: file size check failed, aborting commit" >&2
    exit 1
  fi
fi

# Enforce validate* prefix on all exported functions in *-validation.ts files.
# Every function a validation module exports is a validation entry point; naming
# it validate* makes that contract self-documenting and grep-friendly.
if git diff --cached --name-only | grep -qE '^src/.*-validation\.ts$'; then
  if ! node scripts/check-validate-prefix.mjs; then
    echo "pre-commit: validate* prefix check failed, aborting commit" >&2
    exit 1
  fi
fi
