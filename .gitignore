# NOTE: we are just going to dump a bunch of filename
# and folder patterns used by common programming tools
# here. This does not mean we are using all these tools;
# some of these are just for future-proofing.

# ===================
# Node.js / npm
# ===================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# NAPI-RS platform-specific native binaries (from @nanalogue/node)
*.node

# ===================
# TypeScript
# ===================
dist/
*.tsbuildinfo

# ===================
# Electron
# ===================
out/

# ===================
# Data files (large BAM/BED files)
# ===================
temp_data/
/*.bam
/*.bam.bai

# ===================
# Testing
# ===================
coverage/
.nyc_output/
*.lcov
test-results/

# ===================
# IDEs and Editors
# ===================
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ===================
# OS Files
# ===================
.DS_Store
Thumbs.db
Desktop.ini

# ===================
# Environment
# ===================
.env
.env.local
.env.*.local

# ===================
# Project-specific (local development)
# ===================
# Sandbox temp files created by bash() inside the allowed directory
ai_chat_temp_files/
# SVG/file outputs written by plot_histogram and other sandbox tools
ai_chat_output/
# Claude AI assistant files
.claude/
docs/

# Pi coding agent files
.pi/

# Local brainstorming notes (not for GitHub)
brainstorming*

# Logs
*.log

# Temporary files
tmp*
temp/
*.tmp

# Local configuration overrides
ignore*
slurm*
coderabbit.md
commit_message

# Git worktrees (isolated workspaces)
.worktrees/

# Backup files
bkup/
*.bak
*.backup

# HPC/cluster artifacts
cargo.def
cargo.img
